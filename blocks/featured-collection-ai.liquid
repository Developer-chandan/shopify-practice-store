{% doc %}
  @prompt
    I want to generate a custom section for  featured collection. I want to have the full customization options for product cards and  elements. 
    
    Product card direction:
     - Rounded corner
    - Image 
    - Title
    - Review starts (if available)
    - main price, discount price and pills for percentage of discount
    
    
    At the bottom of part of the section, I want a View All Button
    
    Generate the necessery code and giude me how can I place it in theme
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-featured-collection-{{ ai_gen_id }} {
    display: block;
    width: 100%;
    padding: {{ block.settings.section_padding_top }}px 0 {{ block.settings.section_padding_bottom }}px;
    background-color: {{ block.settings.background_color }};
  }

  .ai-featured-collection__container-{{ ai_gen_id }} {
    max-width: {{ block.settings.container_width }}px;
    margin: 0 auto;
    padding: 0 20px;
  }

  .ai-featured-collection__header-{{ ai_gen_id }} {
    text-align: {{ block.settings.heading_alignment }};
    margin-bottom: {{ block.settings.heading_spacing }}px;
  }

  .ai-featured-collection__title-{{ ai_gen_id }} {
    font-size: {{ block.settings.heading_size }}px;
    color: {{ block.settings.heading_color }};
    margin: 0 0 {{ block.settings.subheading_spacing }}px;
    font-weight: 600;
  }

  .ai-featured-collection__subtitle-{{ ai_gen_id }} {
    font-size: {{ block.settings.subheading_size }}px;
    color: {{ block.settings.subheading_color }};
    margin: 0;
  }

  .ai-featured-collection__grid-{{ ai_gen_id }} {
    display: grid;
    grid-template-columns: repeat({{ block.settings.columns_desktop }}, 1fr);
    gap: {{ block.settings.grid_gap }}px;
    margin-bottom: {{ block.settings.button_spacing }}px;
  }

  @media screen and (max-width: 749px) {
    .ai-featured-collection__grid-{{ ai_gen_id }} {
      grid-template-columns: repeat({{ block.settings.columns_mobile }}, 1fr);
    }
  }

  .ai-product-card-{{ ai_gen_id }} {
    display: flex;
    flex-direction: column;
    background-color: {{ block.settings.card_background }};
    border-radius: {{ block.settings.card_border_radius }}px;
    overflow: hidden;
    transition: transform 0.3s ease, box-shadow 0.3s ease;
    box-shadow: {{ block.settings.card_shadow_horizontal }}px {{ block.settings.card_shadow_vertical }}px {{ block.settings.card_shadow_blur }}px rgba(0, 0, 0, {{ block.settings.card_shadow_opacity }});
  }

  .ai-product-card-{{ ai_gen_id }}:hover {
    transform: translateY(-{{ block.settings.card_hover_lift }}px);
    box-shadow: {{ block.settings.card_shadow_horizontal }}px {{ block.settings.card_shadow_vertical | plus: 4 }}px {{ block.settings.card_shadow_blur | plus: 5 }}px rgba(0, 0, 0, {{ block.settings.card_shadow_opacity | plus: 0.1 }});
  }

  .ai-product-card__image-wrapper-{{ ai_gen_id }} {
    position: relative;
    width: 100%;
    padding-top: {{ block.settings.image_aspect_ratio }}%;
    overflow: hidden;
    border-radius: {{ block.settings.image_border_radius }}px;
  }

  .ai-product-card__image-{{ ai_gen_id }} {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.3s ease;
  }

  .ai-product-card-{{ ai_gen_id }}:hover .ai-product-card__image-{{ ai_gen_id }} {
    transform: scale({{ block.settings.image_hover_scale }});
  }

  .ai-product-card__badge-{{ ai_gen_id }} {
    position: absolute;
    top: {{ block.settings.badge_position_top }}px;
    right: {{ block.settings.badge_position_right }}px;
    background-color: {{ block.settings.badge_background }};
    color: {{ block.settings.badge_text_color }};
    padding: 6px 12px;
    border-radius: {{ block.settings.badge_border_radius }}px;
    font-size: {{ block.settings.badge_font_size }}px;
    font-weight: 600;
    z-index: 2;
  }

  .ai-product-card__content-{{ ai_gen_id }} {
    padding: {{ block.settings.card_padding }}px;
    display: flex;
    flex-direction: column;
    gap: {{ block.settings.content_gap }}px;
    flex-grow: 1;
  }

  .ai-product-card__title-{{ ai_gen_id }} {
    font-size: {{ block.settings.title_font_size }}px;
    color: {{ block.settings.title_color }};
    margin: 0;
    font-weight: 500;
    line-height: 1.3;
    text-align: {{ block.settings.card_text_alignment }};
  }

  .ai-product-card__title-link-{{ ai_gen_id }} {
    color: inherit;
    text-decoration: none;
  }

  .ai-product-card__title-link-{{ ai_gen_id }}:hover {
    color: {{ block.settings.title_hover_color }};
  }

  .ai-product-card__reviews-{{ ai_gen_id }} {
    display: flex;
    align-items: center;
    gap: 8px;
    justify-content: {{ block.settings.card_text_alignment }};
  }

  .ai-product-card__stars-{{ ai_gen_id }} {
    display: flex;
    gap: 2px;
  }

  .ai-product-card__star-{{ ai_gen_id }} {
    width: {{ block.settings.star_size }}px;
    height: {{ block.settings.star_size }}px;
    fill: {{ block.settings.star_color }};
  }

  .ai-product-card__star--empty-{{ ai_gen_id }} {
    fill: {{ block.settings.star_empty_color }};
  }

  .ai-product-card__review-count-{{ ai_gen_id }} {
    font-size: {{ block.settings.review_count_size }}px;
    color: {{ block.settings.review_count_color }};
  }

  .ai-product-card__price-wrapper-{{ ai_gen_id }} {
    display: flex;
    align-items: center;
    gap: 10px;
    flex-wrap: wrap;
    justify-content: {{ block.settings.card_text_alignment }};
  }

  .ai-product-card__price-{{ ai_gen_id }} {
    font-size: {{ block.settings.price_font_size }}px;
    color: {{ block.settings.price_color }};
    font-weight: 600;
  }

  .ai-product-card__compare-price-{{ ai_gen_id }} {
    font-size: {{ block.settings.compare_price_font_size }}px;
    color: {{ block.settings.compare_price_color }};
    text-decoration: line-through;
  }

  .ai-product-card__discount-badge-{{ ai_gen_id }} {
    background-color: {{ block.settings.discount_badge_background }};
    color: {{ block.settings.discount_badge_text }};
    padding: 4px 8px;
    border-radius: {{ block.settings.discount_badge_radius }}px;
    font-size: {{ block.settings.discount_badge_font_size }}px;
    font-weight: 600;
  }

  .ai-featured-collection__footer-{{ ai_gen_id }} {
    text-align: {{ block.settings.button_alignment }};
  }

  .ai-featured-collection__button-{{ ai_gen_id }} {
    display: inline-block;
    padding: {{ block.settings.button_padding_vertical }}px {{ block.settings.button_padding_horizontal }}px;
    background-color: {{ block.settings.button_background }};
    color: {{ block.settings.button_text_color }};
    text-decoration: none;
    border-radius: {{ block.settings.button_border_radius }}px;
    font-size: {{ block.settings.button_font_size }}px;
    font-weight: 600;
    transition: all 0.3s ease;
    border: {{ block.settings.button_border_width }}px solid {{ block.settings.button_border_color }};
  }

  .ai-featured-collection__button-{{ ai_gen_id }}:hover {
    background-color: {{ block.settings.button_hover_background }};
    color: {{ block.settings.button_hover_text }};
    border-color: {{ block.settings.button_hover_border }};
    transform: translateY(-2px);
  }

  .ai-featured-collection__empty-{{ ai_gen_id }} {
    text-align: center;
    padding: 60px 20px;
    color: #666;
  }

  .ai-featured-collection__empty-title-{{ ai_gen_id }} {
    font-size: 24px;
    margin-bottom: 10px;
  }

  .ai-featured-collection__empty-text-{{ ai_gen_id }} {
    font-size: 16px;
  }
{% endstyle %}

<featured-collection-{{ ai_gen_id }}
  class="ai-featured-collection-{{ ai_gen_id }}"
  {{ block.shopify_attributes }}
>
  <div class="ai-featured-collection__container-{{ ai_gen_id }}">
    {% if block.settings.heading != blank or block.settings.subheading != blank %}
      <div class="ai-featured-collection__header-{{ ai_gen_id }}">
        {% if block.settings.heading != blank %}
          <h2 class="ai-featured-collection__title-{{ ai_gen_id }}">{{ block.settings.heading }}</h2>
        {% endif %}
        {% if block.settings.subheading != blank %}
          <p class="ai-featured-collection__subtitle-{{ ai_gen_id }}">{{ block.settings.subheading }}</p>
        {% endif %}
      </div>
    {% endif %}

    {% if block.settings.collection != blank %}
      {% assign collection = block.settings.collection %}
      {% assign products_to_show = block.settings.products_to_show %}

      {% if collection.products.size > 0 %}
        <div class="ai-featured-collection__grid-{{ ai_gen_id }}">
          {% for product in collection.products limit: products_to_show %}
            <div class="ai-product-card-{{ ai_gen_id }}">
              <a href="{{ product.url }}" class="ai-product-card__image-wrapper-{{ ai_gen_id }}">
                {% if product.featured_image %}
                  <img
                    src="{{ product.featured_image | image_url: width: 800 }}"
                    alt="{{ product.featured_image.alt | escape }}"
                    class="ai-product-card__image-{{ ai_gen_id }}"
                    loading="lazy"
                    width="800"
                    height="{{ 800 | times: block.settings.image_aspect_ratio | divided_by: 100 }}"
                  >
                {% else %}
                  <div class="ai-product-card__image-{{ ai_gen_id }}">
                    {{ 'product-1' | placeholder_svg_tag }}
                  </div>
                {% endif %}

                {% if block.settings.show_discount_badge and product.compare_at_price > product.price %}
                  {% assign discount_percentage = product.compare_at_price | minus: product.price | times: 100 | divided_by: product.compare_at_price %}
                  <div class="ai-product-card__badge-{{ ai_gen_id }}">
                    -{{ discount_percentage }}%
                  </div>
                {% endif %}
              </a>

              <div class="ai-product-card__content-{{ ai_gen_id }}">
                {% if block.settings.show_title %}
                  <h3 class="ai-product-card__title-{{ ai_gen_id }}">
                    <a href="{{ product.url }}" class="ai-product-card__title-link-{{ ai_gen_id }}">
                      {{ product.title }}
                    </a>
                  </h3>
                {% endif %}

                {% if block.settings.show_reviews %}
                  <div class="ai-product-card__reviews-{{ ai_gen_id }}">
                    <div class="ai-product-card__stars-{{ ai_gen_id }}">
                      {% assign rating = block.settings.default_rating %}
                      {% for i in (1..5) %}
                        <svg class="ai-product-card__star-{{ ai_gen_id }} {% if i > rating %}ai-product-card__star--empty-{{ ai_gen_id }}{% endif %}" viewBox="0 0 24 24">
                          <path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/>
                        </svg>
                      {% endfor %}
                    </div>
                    {% if block.settings.show_review_count %}
                      <span class="ai-product-card__review-count-{{ ai_gen_id }}">({{ block.settings.default_review_count }})</span>
                    {% endif %}
                  </div>
                {% endif %}

                {% if block.settings.show_price %}
                  <div class="ai-product-card__price-wrapper-{{ ai_gen_id }}">
                    <span class="ai-product-card__price-{{ ai_gen_id }}">
                      {{ product.price | money }}
                    </span>

                    {% if product.compare_at_price > product.price %}
                      <span class="ai-product-card__compare-price-{{ ai_gen_id }}">
                        {{ product.compare_at_price | money }}
                      </span>

                      {% if block.settings.show_discount_pill %}
                        {% assign discount_percentage = product.compare_at_price | minus: product.price | times: 100 | divided_by: product.compare_at_price %}
                        <span class="ai-product-card__discount-badge-{{ ai_gen_id }}">
                          -{{ discount_percentage }}%
                        </span>
                      {% endif %}
                    {% endif %}
                  </div>
                {% endif %}
              </div>
            </div>
          {% endfor %}
        </div>

        {% if block.settings.show_view_all_button %}
          <div class="ai-featured-collection__footer-{{ ai_gen_id }}">
            <a href="{{ collection.url }}" class="ai-featured-collection__button-{{ ai_gen_id }}">
              {{ block.settings.button_text }}
            </a>
          </div>
        {% endif %}
      {% else %}
        <div class="ai-featured-collection__empty-{{ ai_gen_id }}">
          <h3 class="ai-featured-collection__empty-title-{{ ai_gen_id }}">No products in this collection</h3>
          <p class="ai-featured-collection__empty-text-{{ ai_gen_id }}">Add products to this collection to display them here.</p>
        </div>
      {% endif %}
    {% else %}
      <div class="ai-featured-collection__empty-{{ ai_gen_id }}">
        <h3 class="ai-featured-collection__empty-title-{{ ai_gen_id }}">Select a collection</h3>
        <p class="ai-featured-collection__empty-text-{{ ai_gen_id }}">Choose a collection from the block settings to get started.</p>
      </div>
    {% endif %}
  </div>
</featured-collection-{{ ai_gen_id }}>

<script>
  (function() {
    class FeaturedCollection{{ ai_gen_id }} extends HTMLElement {
      constructor() {
        super();
      }

      connectedCallback() {
        this.initializeCards();
      }

      initializeCards() {
        const cards = this.querySelectorAll('.ai-product-card-{{ ai_gen_id }}');
        cards.forEach(card => {
          card.addEventListener('mouseenter', () => {
            card.style.zIndex = '10';
          });
          card.addEventListener('mouseleave', () => {
            card.style.zIndex = '1';
          });
        });
      }
    }

    customElements.define('featured-collection-{{ ai_gen_id }}', FeaturedCollection{{ ai_gen_id }});
  })();
</script>

