{% doc %}
  @prompt
    Create a hero section with the following design elements:- Split layout with text content on the left and image on the right- Left side contains:  - Large bold heading "FIND CLOTHES THAT MATCHES YOUR STYLE" in black, extra bold font  - Descriptive subtext below the heading  - Black rounded "Shop Now" button  - Statistics row showing three metrics: "200  International Brands", "2,000  High-Quality Products", "30,000  Happy Customers"- Right side displays a lifestyle product image of models wearing clothing- Decorative star icons positioned around the section- Light gray/off-white background color- Responsive design that stacks on mobile devices- Clean, modern e-commerce aesthetic with proper spacing and typography
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-hero-section-{{ ai_gen_id }} {
    display: block;
    width: 100%;
    background-color: {{ block.settings.background_color }};
    padding: {{ block.settings.section_padding_top }}px 20px {{ block.settings.section_padding_bottom }}px;
    position: relative;
    overflow: hidden;
  }

  .ai-hero-container-{{ ai_gen_id }} {
    max-width: {{ block.settings.max_width }}px;
    margin: 0 auto;
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 40px;
    align-items: center;
  }

  .ai-hero-content-{{ ai_gen_id }} {
    position: relative;
    z-index: 2;
  }

  .ai-hero-heading-{{ ai_gen_id }} {
    font-size: {{ block.settings.heading_size }}px;
    font-weight: 900;
    color: {{ block.settings.heading_color }};
    line-height: 1.1;
    margin: 0 0 20px;
  }

  .ai-hero-subtext-{{ ai_gen_id }} {
    font-size: {{ block.settings.subtext_size }}px;
    color: {{ block.settings.subtext_color }};
    line-height: 1.6;
    margin: 0 0 30px;
  }

  .ai-hero-button-{{ ai_gen_id }} {
    display: inline-block;
    padding: {{ block.settings.button_padding_vertical }}px {{ block.settings.button_padding_horizontal }}px;
    background-color: {{ block.settings.button_color }};
    color: {{ block.settings.button_text_color }};
    text-decoration: none;
    border-radius: {{ block.settings.button_radius }}px;
    font-size: {{ block.settings.button_font_size }}px;
    font-weight: 600;
    transition: all 0.3s ease;
    border: none;
    cursor: pointer;
  }

  .ai-hero-button-{{ ai_gen_id }}:hover {
    background-color: {{ block.settings.button_hover_color }};
    color: {{ block.settings.button_hover_text_color }};
  }

  .ai-hero-stats-{{ ai_gen_id }} {
    display: flex;
    gap: 30px;
    margin-top: 40px;
    flex-wrap: wrap;
  }

  .ai-hero-stat-{{ ai_gen_id }} {
    display: flex;
    flex-direction: column;
  }

  .ai-hero-stat-number-{{ ai_gen_id }} {
    font-size: {{ block.settings.stat_number_size }}px;
    font-weight: 700;
    color: {{ block.settings.stat_number_color }};
    line-height: 1.2;
  }

  .ai-hero-stat-label-{{ ai_gen_id }} {
    font-size: {{ block.settings.stat_label_size }}px;
    color: {{ block.settings.stat_label_color }};
    margin-top: 5px;
  }

  .ai-hero-image-wrapper-{{ ai_gen_id }} {
    position: relative;
    width: 100%;
    height: 100%;
    min-height: 400px;
  }

  .ai-hero-image-{{ ai_gen_id }} {
    width: 100%;
    height: 100%;
    object-fit: cover;
    border-radius: {{ block.settings.image_radius }}px;
  }

  .ai-hero-image-placeholder-{{ ai_gen_id }} {
    width: 100%;
    height: 100%;
    min-height: 400px;
    background-color: #f4f4f4;
    border-radius: {{ block.settings.image_radius }}px;
    display: flex;
    align-items: center;
    justify-content: center;
    position: relative;
  }

  .ai-hero-image-placeholder-{{ ai_gen_id }} svg {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .ai-hero-empty-state-{{ ai_gen_id }} {
    position: absolute;
    bottom: 20px;
    left: 50%;
    transform: translateX(-50%);
    padding: 12px 20px;
    font-size: 14px;
    color: #666;
    text-align: center;
    pointer-events: none;
  }

  .ai-hero-star-{{ ai_gen_id }} {
    position: absolute;
    z-index: 1;
  }

  .ai-hero-star-{{ ai_gen_id }} svg {
    width: {{ block.settings.star_size }}px;
    height: {{ block.settings.star_size }}px;
    fill: {{ block.settings.star_color }};
  }

  .ai-hero-star-1-{{ ai_gen_id }} {
    top: {{ block.settings.star_1_top }}%;
    left: {{ block.settings.star_1_left }}%;
  }

  .ai-hero-star-2-{{ ai_gen_id }} {
    top: {{ block.settings.star_2_top }}%;
    left: {{ block.settings.star_2_left }}%;
  }

  .ai-hero-star-3-{{ ai_gen_id }} {
    top: {{ block.settings.star_3_top }}%;
    right: {{ block.settings.star_3_right }}%;
  }

  .ai-hero-star-4-{{ ai_gen_id }} {
    bottom: {{ block.settings.star_4_bottom }}%;
    right: {{ block.settings.star_4_right }}%;
  }

  @media screen and (max-width: 749px) {
    .ai-hero-container-{{ ai_gen_id }} {
      grid-template-columns: 1fr;
      gap: 30px;
    }

    .ai-hero-heading-{{ ai_gen_id }} {
      font-size: calc({{ block.settings.heading_size }}px * 0.6);
    }

    .ai-hero-subtext-{{ ai_gen_id }} {
      font-size: calc({{ block.settings.subtext_size }}px * 0.9);
    }

    .ai-hero-stats-{{ ai_gen_id }} {
      gap: 20px;
      margin-top: 30px;
    }

    .ai-hero-stat-number-{{ ai_gen_id }} {
      font-size: calc({{ block.settings.stat_number_size }}px * 0.8);
    }

    .ai-hero-stat-label-{{ ai_gen_id }} {
      font-size: calc({{ block.settings.stat_label_size }}px * 0.9);
    }

    .ai-hero-image-wrapper-{{ ai_gen_id }} {
      min-height: 300px;
    }

    .ai-hero-image-placeholder-{{ ai_gen_id }} {
      min-height: 300px;
    }

    .ai-hero-star-{{ ai_gen_id }} svg {
      width: calc({{ block.settings.star_size }}px * 0.7);
      height: calc({{ block.settings.star_size }}px * 0.7);
    }
  }
{% endstyle %}

<hero-section-{{ ai_gen_id }} class="ai-hero-section-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  {% if block.settings.show_stars %}
    <div class="ai-hero-star-{{ ai_gen_id }} ai-hero-star-1-{{ ai_gen_id }}">
      <svg viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
        <path d="M12 2L15.09 8.26L22 9.27L17 14.14L18.18 21.02L12 17.77L5.82 21.02L7 14.14L2 9.27L8.91 8.26L12 2Z"/>
      </svg>
    </div>
    <div class="ai-hero-star-{{ ai_gen_id }} ai-hero-star-2-{{ ai_gen_id }}">
      <svg viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
        <path d="M12 2L15.09 8.26L22 9.27L17 14.14L18.18 21.02L12 17.77L5.82 21.02L7 14.14L2 9.27L8.91 8.26L12 2Z"/>
      </svg>
    </div>
    <div class="ai-hero-star-{{ ai_gen_id }} ai-hero-star-3-{{ ai_gen_id }}">
      <svg viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
        <path d="M12 2L15.09 8.26L22 9.27L17 14.14L18.18 21.02L12 17.77L5.82 21.02L7 14.14L2 9.27L8.91 8.26L12 2Z"/>
      </svg>
    </div>
    <div class="ai-hero-star-{{ ai_gen_id }} ai-hero-star-4-{{ ai_gen_id }}">
      <svg viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
        <path d="M12 2L15.09 8.26L22 9.27L17 14.14L18.18 21.02L12 17.77L5.82 21.02L7 14.14L2 9.27L8.91 8.26L12 2Z"/>
      </svg>
    </div>
  {% endif %}

  <div class="ai-hero-container-{{ ai_gen_id }}">
    <div class="ai-hero-content-{{ ai_gen_id }}">
      {% if block.settings.heading != blank %}
        <h1 class="ai-hero-heading-{{ ai_gen_id }}">{{ block.settings.heading }}</h1>
      {% endif %}

      {% if block.settings.subtext != blank %}
        <div class="ai-hero-subtext-{{ ai_gen_id }}">{{ block.settings.subtext }}</div>
      {% endif %}

      {% if block.settings.button_text != blank %}
        <a href="{{ block.settings.button_link }}" class="ai-hero-button-{{ ai_gen_id }}">
          {{ block.settings.button_text }}
        </a>
      {% endif %}

      {% if block.settings.show_stats %}
        <div class="ai-hero-stats-{{ ai_gen_id }}">
          {% if block.settings.stat_1_number != blank %}
            <div class="ai-hero-stat-{{ ai_gen_id }}">
              <div class="ai-hero-stat-number-{{ ai_gen_id }}">{{ block.settings.stat_1_number }}</div>
              <div class="ai-hero-stat-label-{{ ai_gen_id }}">{{ block.settings.stat_1_label }}</div>
            </div>
          {% endif %}

          {% if block.settings.stat_2_number != blank %}
            <div class="ai-hero-stat-{{ ai_gen_id }}">
              <div class="ai-hero-stat-number-{{ ai_gen_id }}">{{ block.settings.stat_2_number }}</div>
              <div class="ai-hero-stat-label-{{ ai_gen_id }}">{{ block.settings.stat_2_label }}</div>
            </div>
          {% endif %}

          {% if block.settings.stat_3_number != blank %}
            <div class="ai-hero-stat-{{ ai_gen_id }}">
              <div class="ai-hero-stat-number-{{ ai_gen_id }}">{{ block.settings.stat_3_number }}</div>
              <div class="ai-hero-stat-label-{{ ai_gen_id }}">{{ block.settings.stat_3_label }}</div>
            </div>
          {% endif %}
        </div>
      {% endif %}
    </div>

    <div class="ai-hero-image-wrapper-{{ ai_gen_id }}">
      {% if block.settings.image %}
        <img
          src="{{ block.settings.image | image_url: width: 1200 }}"
          alt="{{ block.settings.image.alt | escape }}"
          loading="lazy"
          width="{{ block.settings.image.width }}"
          height="{{ block.settings.image.height }}"
          class="ai-hero-image-{{ ai_gen_id }}"
        >
      {% else %}
        <div class="ai-hero-image-placeholder-{{ ai_gen_id }}">
          {{ 'hero-apparel-1' | placeholder_svg_tag }}
          <div class="ai-hero-empty-state-{{ ai_gen_id }}">
            Next, add a lifestyle image
          </div>
        </div>
      {% endif %}
    </div>
  </div>
</hero-section-{{ ai_gen_id }}>

{% schema %}
