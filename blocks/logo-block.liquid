
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-logo-showcase-{{ ai_gen_id }} {
    display: block;
    width: 100%;
    background-color: {{ block.settings.background_color }};
    padding: {{ block.settings.padding_top }}px 0 {{ block.settings.padding_bottom }}px;
  }

  .ai-logo-showcase-container-{{ ai_gen_id }} {
    max-width: {{ block.settings.container_width }}px;
    margin: 0 auto;
    padding: 0 20px;
  }

  .ai-logo-showcase-heading-{{ ai_gen_id }} {
    text-align: center;
    color: {{ block.settings.heading_color }};
    font-size: {{ block.settings.heading_size }}px;
    margin: 0 0 {{ block.settings.heading_spacing }}px;
  }

  .ai-logo-showcase-grid-{{ ai_gen_id }} {
    display: grid;
    grid-template-columns: repeat({{ block.settings.columns_desktop }}, 1fr);
    grid-template-rows: repeat({{ block.settings.rows_desktop }}, 1fr);
    gap: {{ block.settings.gap_desktop }}px;
    align-items: center;
  }

  .ai-logo-showcase-item-{{ ai_gen_id }} {
    display: flex;
    align-items: center;
    justify-content: center;
    padding: {{ block.settings.logo_padding }}px;
  }

  .ai-logo-showcase-image-{{ ai_gen_id }} {
    max-width: 100%;
    height: auto;
    max-height: {{ block.settings.logo_max_height }}px;
    width: auto;
    object-fit: contain;
    filter: {{ block.settings.logo_filter }};
    transition: filter 0.3s ease;
  }

  .ai-logo-showcase-image-{{ ai_gen_id }}:hover {
    filter: {{ block.settings.logo_filter_hover }};
  }

  .ai-logo-showcase-placeholder-{{ ai_gen_id }} {
    width: 100%;
    height: {{ block.settings.logo_max_height }}px;
    display: flex;
    align-items: center;
    justify-content: center;
    background-color: rgba(255, 255, 255, 0.1);
    border-radius: 8px;
    position: relative;
  }

  .ai-logo-showcase-placeholder-{{ ai_gen_id }} svg {
    width: 60%;
    height: 60%;
    opacity: 0.3;
  }

  .ai-logo-showcase-empty-state-{{ ai_gen_id }} {
    position: absolute;
    bottom: 10px;
    left: 50%;
    transform: translateX(-50%);
    font-size: 12px;
    color: {{ block.settings.heading_color }};
    opacity: 0.6;
    white-space: nowrap;
  }

  @media screen and (max-width: 749px) {
    .ai-logo-showcase-grid-{{ ai_gen_id }} {
      grid-template-columns: repeat({{ block.settings.columns_mobile }}, 1fr);
      grid-template-rows: auto;
      gap: {{ block.settings.gap_mobile }}px;
      justify-content: center;
    }

    .ai-logo-showcase-heading-{{ ai_gen_id }} {
      font-size: calc({{ block.settings.heading_size }}px * 0.8);
    }
  }
{% endstyle %}

<logo-showcase-{{ ai_gen_id }} class="ai-logo-showcase-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  <div class="ai-logo-showcase-container-{{ ai_gen_id }}">
    {% if block.settings.show_heading and block.settings.heading != blank %}
      <h2 class="ai-logo-showcase-heading-{{ ai_gen_id }}">{{ block.settings.heading }}</h2>
    {% endif %}

    <div class="ai-logo-showcase-grid-{{ ai_gen_id }}">
      {% for i in (1..12) %}
        {% assign logo_key = 'logo_' | append: i %}
        {% assign logo = block.settings[logo_key] %}
        
        {% if logo != blank %}
          <div class="ai-logo-showcase-item-{{ ai_gen_id }}">
            <img
              src="{{ logo | image_url: width: 400 }}"
              alt="{{ logo.alt | escape }}"
              loading="lazy"
              width="{{ logo.width }}"
              height="{{ logo.height }}"
              class="ai-logo-showcase-image-{{ ai_gen_id }}"
            >
          </div>
        {% elsif forloop.index <= 5 %}
          <div class="ai-logo-showcase-item-{{ ai_gen_id }}">
            <div class="ai-logo-showcase-placeholder-{{ ai_gen_id }}">
              {{ 'image' | placeholder_svg_tag }}
              <div class="ai-logo-showcase-empty-state-{{ ai_gen_id }}">
                Add logo {{ forloop.index }}
              </div>
            </div>
          </div>
        {% endif %}
      {% endfor %}
    </div>
  </div>
</logo-showcase-{{ ai_gen_id }}>

{% schema %}
{
  "name": "Logo showcase",
  "settings": [
    {
      "type": "header",
      "content": "Content"
    },
    {
      "type": "checkbox",
      "id": "show_heading",
      "label": "Show heading",
      "default": true
    },
    {
      "type": "inline_richtext",
      "id": "heading",
      "label": "Heading",
      "default": "Trusted by leading brands"
    },
    {
      "type": "range",
      "id": "heading_size",
      "label": "Heading size",
      "min": 16,
      "max": 48,
      "step": 2,
      "unit": "px",
      "default": 32
    },
    {
      "type": "range",
      "id": "heading_spacing",
      "label": "Heading spacing",
      "min": 0,
      "max": 80,
      "step": 4,
      "unit": "px",
      "default": 40
    },
    {
      "type": "header",
      "content": "Layout"
    },
    {
      "type": "range",
      "id": "columns_desktop",
      "label": "Columns on desktop",
      "min": 3,
      "max": 8,
      "step": 1,
      "default": 5
    },
    {
      "type": "range",
      "id": "rows_desktop",
      "label": "Rows on desktop",
      "min": 1,
      "max": 3,
      "step": 1,
      "default": 1
    },
    {
      "type": "select",
      "id": "columns_mobile",
      "label": "Columns on mobile",
      "options": [
        {
          "value": "2",
          "label": "2"
        },
        {
          "value": "3",
          "label": "3"
        }
      ],
      "default": "3"
    },
    {
      "type": "range",
      "id": "gap_desktop",
      "label": "Gap on desktop",
      "min": 0,
      "max": 80,
      "step": 4,
      "unit": "px",
      "default": 40
    },
    {
      "type": "range",
      "id": "gap_mobile",
      "label": "Gap on mobile",
      "min": 0,
      "max": 40,
      "step": 4,
      "unit": "px",
      "default": 20
    },
    {
      "type": "range",
      "id": "container_width",
      "label": "Container width",
      "min": 800,
      "max": 1600,
      "step": 100,
      "unit": "px",
      "default": 1200
    },
    {
      "type": "header",
      "content": "Logo style"
    },
    {
      "type": "range",
      "id": "logo_max_height",
      "label": "Logo max height",
      "min": 40,
      "max": 200,
      "step": 10,
      "unit": "px",
      "default": 80
    },
    {
      "type": "range",
      "id": "logo_padding",
      "label": "Logo padding",
      "min": 0,
      "max": 40,
      "step": 4,
      "unit": "px",
      "default": 16
    },
    {
      "type": "select",
      "id": "logo_filter",
      "label": "Logo filter",
      "options": [
        {
          "value": "none",
          "label": "None"
        },
        {
          "value": "grayscale(100%)",
          "label": "Grayscale"
        },
        {
          "value": "brightness(0) invert(1)",
          "label": "White"
        },
        {
          "value": "opacity(0.6)",
          "label": "Faded"
        }
      ],
      "default": "brightness(0) invert(1)"
    },
    {
      "type": "select",
      "id": "logo_filter_hover",
      "label": "Logo filter on hover",
      "options": [
        {
          "value": "none",
          "label": "None"
        },
        {
          "value": "grayscale(100%)",
          "label": "Grayscale"
        },
        {
          "value": "brightness(0) invert(1)",
          "label": "White"
        },
        {
          "value": "opacity(0.6)",
          "label": "Faded"
        }
      ],
      "default": "none"
    },
    {
      "type": "header",
      "content": "Colors"
    },
    {
      "type": "color",
      "id": "background_color",
      "label": "Background",
      "default": "#000000"
    },
    {
      "type": "color",
      "id": "heading_color",
      "label": "Heading",
      "default": "#ffffff"
    },
    {
      "type": "header",
      "content": "Spacing"
    },
    {
      "type": "range",
      "id": "padding_top",
      "label": "Padding top",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "default": 60
    },
    {
